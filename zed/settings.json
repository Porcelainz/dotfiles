// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "project_panel": {
        "git_status": true
    },
    "tabs": {
        "file_icons": true
    },
    "title_bar": {
        "show_menus": false
    },
    "buffer_line_height": "comfortable",
    "wsl_connections": [
        {
            "distro_name": "archlinux",
            "user": null,
            "projects": [
                {
                    "paths": [
                        "/home/porcelain_"
                    ]
                },
                {
                    "paths": [
                        "/home/porcelain_/project/github/go-snippet-lab"
                    ]
                }
            ]
        }
    ],
    "icon_theme": "Catppuccin Latte",
    "terminal": {
        "font_size": 14.0,
        "font_family": "Maple Mono NF",
        "font_fallbacks": [
            "Maple Mono NF CN"
        ],
        "line_height": {
            "custom": 0.0
        }
    },
    "base_keymap": "VSCode",
    "minimap": {
        "show": "never"
    },
    "autosave": "on_focus_change",
    "buffer_font_fallbacks": [
        "Maple Mono NF CN"
    ],
    "buffer_font_family": "Maple Mono NF",
    "indent_guides": {
        "enabled": true
    },
    "vim_mode": true,
    "relative_line_numbers": "enabled",
    "scrollbar": {
        "show": "always"
    },
    "cursor_blink": false,
    "vim": {
        "use_system_clipboard": "always"
    },
    "ui_font_size": 16,
    "buffer_font_size": 14.0,
    "theme": {
        "mode": "system",
        "light": "Catppuccin Latte - No Italics",
        "dark": "One Dark"
    },
    "experimental.theme_overrides": {
        "syntax": {
            "comment": {
                "font_style": "normal"
            },
            "keyword": {
                "font_style": "normal"
            },
            "parameter": {
                "font_style": "normal"
            },
            "tag": {
                "font_style": "normal"
            },
            "type": {
                "font_style": "normal"
            },
            "function": {
                "font_style": "normal"
            },
            "property": {
                "font_style": "normal"
            },
            "variable": {
                "color": "#000000"
            }
        }
    }
}